# Copy to .env and fill in real values. Never commit .env.
#
# Quick secret generation:
#   SECRET_KEY_BASE:  openssl rand -base64 64 | tr -d '\n'
#   RELEASE_COOKIE:   openssl rand -base64 48 | tr -d '\n'
#   MMO_DB_PASSWORD:  openssl rand -base64 24 | tr -d '\n'

# ---- Image tag (pulled from Aliyun ACR) ----
IMAGE_TAG=registry.cn-hangzhou.aliyuncs.com/YOUR_NAMESPACE/ex_mmo_cluster:latest

# ---- Domain ----
# Single-domain MVP: one hostname for HTTPS (auth_server) AND TCP gate.
# auth_server reachable at https://${DOMAIN}/, gate_server at ${DOMAIN}:${GATE_TCP_PORT}.
# visualize_server (4001) is NOT exposed publicly — access via SSH tunnel.
DOMAIN=mmo.example.com
PHX_HOST=mmo.example.com

# ---- Phoenix / release secrets ----
SECRET_KEY_BASE=REPLACE_ME_mix_phx_gen_secret
RELEASE_COOKIE=REPLACE_ME_openssl_rand_base64_48
PHX_SERVER=true

# ---- Ports ----
AUTH_PORT=4000
VISUALIZE_PORT=4001
GATE_TCP_PORT=29000
GATE_UDP_PORT=29001

# ---- Database ----
MMO_DB_NAME=ex_mmo_cluster_prod
MMO_DB_USER=ex_mmo_cluster
MMO_DB_PASSWORD=REPLACE_ME
MMO_DB_PORT=5432
MMO_DB_POOL_SIZE=10
# MMO_DB_HOST is hard-overridden to "postgres" by docker-compose.yml

# ---- Cluster (MVP single-container) ----
DISABLE_CLUSTER=true
RELEASE_DISTRIBUTION=none

# ---- Dev-only toggles ----
# DEV_AUTO_LOGIN enables POST /ingame/auto_login, which bootstraps a signed
# token from just a username (no password). Leave it unset for production —
# runtime.exs raises at boot when this flag is true under MIX_ENV=prod.
# DEV_AUTO_LOGIN=true
