# Copy to .env and fill in real values. Never commit .env.
#
# Quick secret generation:
#   SECRET_KEY_BASE:  openssl rand -base64 64 | tr -d '\n'
#   RELEASE_COOKIE:   openssl rand -base64 48 | tr -d '\n'
#   MMO_DB_PASSWORD:  openssl rand -base64 24 | tr -d '\n'

# ---- Image tag (pulled from Aliyun ACR) ----
IMAGE_TAG=registry.cn-hangzhou.aliyuncs.com/your_namespace/ex_mmo_cluster:latest

# ---- 归档 Web 客户端静态包（默认禁用） ----
# 只有用户显式要求部署归档 web_client 时，才把开关改为 true 并填写镜像。
# 日常服务端升级必须保持 false 与空镜像，避免隐式发布归档客户端。
ALLOW_ARCHIVED_WEB_CLIENT_DEPLOY=false
WEB_CLIENT_IMAGE_TAG=
WEB_CLIENT_DIST_DIR=/data/ex_mmo_cluster/web_client/dist

# ---- Domain ----
# Single-domain MVP: one hostname for HTTPS (auth_server) AND TCP gate.
# auth_server reachable at https://${DOMAIN}/, gate_server at ${DOMAIN}:${GATE_TCP_PORT}.
# visualize_server (20001) is NOT exposed publicly — access via SSH tunnel.
DOMAIN=mmo.example.com
PHX_HOST=mmo.example.com

# ---- Phoenix / release secrets ----
SECRET_KEY_BASE=REPLACE_ME_mix_phx_gen_secret
RELEASE_COOKIE=REPLACE_ME_openssl_rand_base64_48
PHX_SERVER=true

# ---- Host-side published ports ----
# docker-compose.yml keeps the release listen ports fixed inside containers
# (auth=20000, visualize=20001, gate_tcp=20002, gate_udp=20003). These values
# are the ports exposed on the host. Keep them at 20000+ for new installs, or
# set them to legacy production ports (for example 14000/14001/29000/29001)
# when upgrading an existing server without changing public endpoints.
AUTH_PORT=20000
VISUALIZE_PORT=20001
GATE_TCP_PORT=20002
GATE_UDP_PORT=20003

# ---- Scene server scaling ----
# Apply with:
#   set -a; . ./.env; set +a
#   docker compose up -d --scale scene=${SCENE_SERVER_COUNT}
# Keep at least 1: app/world startup waits for a scene_server registration.
SCENE_SERVER_COUNT=1

# ---- Database ----
MMO_DB_NAME=ex_mmo_cluster_prod
MMO_DB_USER=ex_mmo_cluster
MMO_DB_PASSWORD=REPLACE_ME
MMO_DB_PORT=5432
MMO_DB_POOL_SIZE=10
# MMO_DB_HOST is hard-overridden to "postgres" by docker-compose.yml

# ---- Cluster (Compose app + scalable scene nodes) ----
DISABLE_CLUSTER=false
RELEASE_DISTRIBUTION=name

# ---- Demo toggles ----
# DEV_AUTO_LOGIN enables POST /ingame/auto_login, which bootstraps a signed
# token from just a username (no password). The shared online deployment is a
# demo/dev environment and keeps this enabled for browser client bootstrap.
DEV_AUTO_LOGIN=true
