# ex_mmo_cluster — nginx reverse proxy 模板
#
# 用法（服务器上）:
#   1. 复制到 /etc/nginx/sites-available/ex_mmo_cluster.conf
#   2. 替换 ${DOMAIN} 占位符为实际域名（auth.example.com / game.example.com 等）
#   3. 替换端口为 .env 里 AUTH_PORT / VISUALIZE_PORT 的值（默认 4000 / 4001）
#   4. ln -s /etc/nginx/sites-available/ex_mmo_cluster.conf /etc/nginx/sites-enabled/
#   5. certbot --nginx -d auth.${DOMAIN} -d game.${DOMAIN}
#   6. nginx -t && systemctl reload nginx
#
# 前置条件:
#   - DNS A 记录 auth.${DOMAIN} / game.${DOMAIN} 已解析到本机公网 IP
#   - docker compose 里 app 已经把 4000/4001 绑到 127.0.0.1
#   - gate_server 的 29000 TCP 端口走防火墙直连，不在这里反代
#
# Phoenix LiveView / Channels 走 WebSocket，必须保留 Upgrade/Connection 头。

# ============================================================================
# auth.${DOMAIN} → auth_server (玩家登录/注册 API)
# ============================================================================
server {
    listen 443 ssl http2;
    server_name auth.${DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/auth.${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/auth.${DOMAIN}/privkey.pem;

    # 一般日志即可；如果要排查链路头问题，开 access_log /var/log/nginx/auth.access.log；
    access_log /var/log/nginx/ex_mmo_cluster-auth.access.log;
    error_log  /var/log/nginx/ex_mmo_cluster-auth.error.log;

    # 客户端上传（注册时可能有头像之类）。按需调整。
    client_max_body_size 4M;

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Phoenix LiveView / Channels
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";

        # 长连接保活
        proxy_read_timeout    3600s;
        proxy_send_timeout    3600s;
        proxy_connect_timeout 60s;
    }
}

# ============================================================================
# game.${DOMAIN} → visualize_server (LiveView 可视化控制台)
# ============================================================================
# 这是后台调试/可视化界面。建议加 IP 白名单或 basic_auth 限制访问。
server {
    listen 443 ssl http2;
    server_name game.${DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/game.${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/game.${DOMAIN}/privkey.pem;

    access_log /var/log/nginx/ex_mmo_cluster-game.access.log;
    error_log  /var/log/nginx/ex_mmo_cluster-game.error.log;

    # ---- 可选：IP 白名单（去掉注释并填入允许访问的 IP/段） ----
    # allow 1.2.3.4/32;
    # allow 10.0.0.0/8;
    # deny  all;

    # ---- 可选：basic auth ----
    # auth_basic           "ex_mmo_cluster Console";
    # auth_basic_user_file /etc/nginx/.htpasswd;

    location / {
        proxy_pass http://127.0.0.1:4001;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";

        proxy_read_timeout    3600s;
        proxy_send_timeout    3600s;
        proxy_connect_timeout 60s;
    }
}

# ============================================================================
# 80 → 443 跳转
# ============================================================================
server {
    listen 80;
    server_name auth.${DOMAIN} game.${DOMAIN};

    # certbot 验证用的 ACME challenge 路径要放行（certbot --nginx 会自动处理）
    location / {
        return 301 https://$host$request_uri;
    }
}
