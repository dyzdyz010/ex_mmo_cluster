# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez


# Temporary files for e.g. tests
/tmp


# VSCode configuration
/.vscode

.mnesia

# Rustler / native build outputs
/apps/*/priv/native/*.so
/apps/*/priv/native/*.dylib
/apps/*/priv/native/*.dll
/apps/*/native/*/target/

.omx/

# OMC runtime state (per-session). Keep autopilot specs and plans tracked.
# Use ** so nested .omc/ directories inside umbrella apps are also ignored.
**/.omc/state/
**/.omc/logs/
**/.omc/sessions/
**/.omc/project-memory.json

# Claude Code local settings
/.claude/
/Mnesia.nonode@nohost/
/apps/beacon_server/MnesiaCore.nonode@nohost_*

clients/bevy_client/target/
.demo/

# Deployment secrets — never commit real .env, but keep .env.example tracked.
deploy/.env
deploy/.env.*
!deploy/.env.example

# Local docker smoke-test client logs.
deploy/*-observe.log
deploy/*-stdout.log
